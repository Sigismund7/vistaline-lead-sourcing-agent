# Copy to .env and fill in.

# Required for orchestrator + LLM agents (lead_filter, owner_researcher)
ANTHROPIC_API_KEY=sk-ant-...

# Required for sourcer.
# Get one at console.cloud.google.com -> Enable "Places API (New)" -> Credentials.
# Restrict the key to the Places API only.
GOOGLE_PLACES_KEY=...

# Optional: override the default niche
DEFAULT_NICHE=bathroom remodeling
