# Copy to .env and fill in.

# Required for orchestrator + LLM agents (lead_filter, owner_researcher)
ANTHROPIC_API_KEY=sk-ant-...

# Required for sourcer.
# Get one at console.cloud.google.com -> Enable "Places API (New)" -> Credentials.
# Restrict the key to the Places API only.
GOOGLE_PLACES_KEY=AIza...

# Optional sourcing layers
AZURE_MAPS_KEY=
YELP_FUSION_KEY=
BRAVE_SEARCH_KEY=

# Owner Researcher v2 — Phase 3 business registry lookup
# Free tier: 50 lookups/day. Paid tier: ~$0.50/1k. Sign up at opencorporates.com/api_accounts/new
OPENCORPORATES_API_KEY=

# Owner Researcher Phase 0 — ScraperAPI proxy for Yelp profile pages
# Yelp's Cloudflare blocks direct fetches; ScraperAPI bypasses it server-side.
# Premium tier: 10 credits/page (~$0.005). Hobby plan ($49/mo) = 100k credits.
# Hard monthly cap of 10,000 credits enforced in state/scraperapi_budget_<YYYY-MM>.json.
# Sign up at scraperapi.com.
SCRAPERAPI_KEY=

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# API auth (shared secret between FastAPI and frontend)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
VISTALINE_API_SECRET=

# Optional
DEFAULT_NICHE=bathroom remodeling
